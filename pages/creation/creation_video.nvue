  align-items: center;
}

.center-icon-inner {
  width: 80px;
  height: 80px;
  border-radius: 40px;
  background-color: rgba(0, 0, 0, 0.4);
  justify-content: center;
  align-items: center;
}

.center-icon-text {
  font-size: 44px;
  color: #ffffff;
}

/* 底部信息 */
.bottom-info {
  position: absolute;
  left: 10px;
  right: 82px;
  bottom: 10px;
}

.author-row {
  margin-bottom: 8px;
}

.author-name {
  font-size: 17px;
  font-weight: 700;
  color: #ffffff;
}

.title-row {
  margin-bottom: 5px;
}

.title-text {
  font-size: 16px;
  color: #ffffff;
  line-height: 20px;
  margin-left: 6px;
}

.detail-row {
  margin-bottom: 2px;
}

.detail-text {
  font-size: 13px;
  color: #f5f5f5;
  line-height: 18px;
  margin-left: 6px;
}

.detail-expand {
  margin-top: 1px;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.9);
}

/* 评论遮罩和抽屉：恢复原始样式 */
.comments-mask {
  position: absolute;
  left: 0;
