  border-radius: 21px;
}

.follow-plus {
  position: absolute;
  bottom: 2px;
  left: 18px;
  width: 20px;
  height: 20px;
  border-radius: 10px;
  background-color: #ff4757;
  border-width: 2px;
  border-style: solid;
  border-color: #ffffff;
  justify-content: center;
  align-items: center;
}

.follow-plus-text {
  font-size: 13px;
